rules_version = '2';

// Kasik App — Firestore Guvenlik Kurallari
// Firebase Console > Firestore > Kurallar sekmesine yapistir

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== YARDIMCI FONKSIYONLAR =====

    // Giris yapmis kullanici mi?
    function isAuthenticated() {
      return request.auth != null;
    }

    // Kullanicinin kendi verisi mi?
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Premium kullanici mi?
    function isPremium() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.subscription.isPremium == true;
    }

    // ===== KULLANICILAR =====
    match /users/{userId} {
      // Herkes profil okuyabilir (topluluk icin)
      allow read: if isAuthenticated();

      // Sadece kendi profilini olusturabilir/guncelleyebilir
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);

      // Hesap silme — sadece kendi
      allow delete: if isOwner(userId);

      // ===== BEBEKLER (subcollection) =====
      match /babies/{babyId} {
        allow read, write: if isOwner(userId);
      }

      // ===== OGUN PLANLARI (subcollection) =====
      match /mealPlans/{planId} {
        allow read, write: if isOwner(userId);
      }

      // ===== DOLAP / PANTRY (subcollection) =====
      match /pantry/{itemId} {
        allow read, write: if isOwner(userId);
      }

      // ===== TARIF DEFTERI (subcollection) =====
      match /recipeBook/{entryId} {
        allow read, write: if isOwner(userId);
      }

      // ===== ALERJEN PROGRAMLARI (subcollection) =====
      match /allergenPrograms/{programId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ===== TARIFLER (herkese acik) =====
    match /recipes/{recipeId} {
      // Herkes tarif okuyabilir
      allow read: if isAuthenticated();

      // Tarif olusturma — giris yapmis herkes
      allow create: if isAuthenticated() &&
        request.resource.data.authorId == request.auth.uid;

      // Guncelleme — yazar veya like/view sayaci
      allow update: if isAuthenticated() && (
        resource.data.authorId == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['likes', 'views', 'likedBy', 'comments'])
      );

      // Silme — sadece yazar
      allow delete: if isAuthenticated() &&
        resource.data.authorId == request.auth.uid;
    }

    // ===== TOPLULUK POSTLARI =====
    match /posts/{postId} {
      // Herkes okuyabilir
      allow read: if isAuthenticated();

      // Post olusturma
      allow create: if isAuthenticated() &&
        request.resource.data.authorId == request.auth.uid;

      // Guncelleme — yazar veya like/view sayaci
      allow update: if isAuthenticated() && (
        resource.data.authorId == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['likes', 'views', 'likedBy', 'comments', 'commentCount'])
      );

      // Silme — sadece yazar
      allow delete: if isAuthenticated() &&
        resource.data.authorId == request.auth.uid;

      // ===== YORUMLAR (Alt koleksiyon) =====
      match /comments/{commentId} {
        allow read: if isAuthenticated();

        allow create: if isAuthenticated() &&
          request.resource.data.authorId == request.auth.uid;

        allow update: if isAuthenticated() &&
          resource.data.authorId == request.auth.uid;

        allow delete: if isAuthenticated() && (
          resource.data.authorId == request.auth.uid ||
          get(/databases/$(database)/documents/posts/$(postId)).data.authorId == request.auth.uid
        );
      }
    }

    // ===== AI TARIF KULLANIM TAKIBI =====
    match /aiUsage/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    // ===== ABONELIKLER =====
    match /subscriptions/{userId} {
      allow read: if isOwner(userId);
      // Sadece sunucu (Cloud Functions) yazabilir
      allow write: if false;
    }

    // ===== BILDIRIM TOKENLARI =====
    match /pushTokens/{tokenId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;

      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;

      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;

      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // ===== RAPORLAR / SIKAYET =====
    match /reports/{reportId} {
      allow create: if isAuthenticated() &&
        request.resource.data.reporterId == request.auth.uid;

      allow read, update, delete: if false;
    }
  }
}
