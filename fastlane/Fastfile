default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: File.expand_path(ENV["ASC_KEY_PATH"]),
      duration: 1200,
      in_house: false
    )

    setup_ci

    # ios/ dizininden workspace bul
    ws = Dir.glob("ios/*.xcworkspace").first
    UI.user_error!("No xcworkspace found in ios/") unless ws
    scheme_name = File.basename(ws, ".xcworkspace")
    xcproj = Dir.glob("ios/*.xcodeproj").first

    UI.message("Workspace: #{ws}")
    UI.message("Scheme: #{scheme_name}")
    UI.message("Project: #{xcproj}")

    update_code_signing_settings(
      use_automatic_signing: true,
      path: xcproj,
      team_id: "32TLAQYSU6"
    )

    build_app(
      workspace: ws,
      scheme: scheme_name,
      export_method: "app-store",
      export_options: {
        signingStyle: "automatic",
        teamID: "32TLAQYSU6"
      },
      clean: true,
      output_directory: "../ios",
      output_name: "kasik-app.ipa"
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
