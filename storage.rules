rules_version = '2';

// Kasik App — Firebase Storage Guvenlik Kurallari
// Firebase Console > Storage > Kurallar sekmesine yapistir

service firebase.storage {
  match /b/{bucket}/o {

    // ===== YARDIMCI =====

    // Giris yapmis mi?
    function isAuthenticated() {
      return request.auth != null;
    }

    // Dosya boyutu limiti (MB cinsinden)
    function maxSize(mb) {
      return request.resource.size < mb * 1024 * 1024;
    }

    // Gorsel dosyasi mi?
    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    // ===== PROFIL FOTOGRAFLARI =====
    // users/{userId}/profile.jpg
    match /users/{userId}/{allPaths=**} {
      // Herkes profil resmini gorebilir
      allow read: if isAuthenticated();

      // Sadece kendi profil resmini yukleyebilir
      allow write: if isAuthenticated()
        && request.auth.uid == userId
        && isImage()
        && maxSize(5);
    }

    // ===== BEBEK FOTOGRAFLARI =====
    // users/{userId}/babies/{babyId}/{filename} — kullaniciya bagli path
    match /users/{userId}/babies/{babyId}/{allPaths=**} {
      // Sadece sahibi okuyabilir/yazabilir
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated()
        && request.auth.uid == userId
        && isImage()
        && maxSize(5);
    }

    // Eski path icin geriye uyumluluk (sadece okuma)
    match /babies/{babyId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ===== TARIF FOTOGRAFLARI =====
    // recipes/{recipeId}/{filename}
    match /recipes/{recipeId}/{allPaths=**} {
      allow read: if isAuthenticated();

      // Yazma — sadece tarif yazari (Firestore'dan kontrol)
      allow write: if isAuthenticated()
        && isImage()
        && maxSize(10)
        && firestore.get(/databases/(default)/documents/recipes/$(recipeId)).data.authorId == request.auth.uid;
    }

    // ===== TOPLULUK POST FOTOGRAFLARI =====
    // posts/{postId}/{filename}
    match /posts/{postId}/{allPaths=**} {
      allow read: if isAuthenticated();

      // Yazma — sadece post yazari (Firestore'dan kontrol)
      allow write: if isAuthenticated()
        && isImage()
        && maxSize(10)
        && firestore.get(/databases/(default)/documents/posts/$(postId)).data.authorId == request.auth.uid;
    }

    // ===== YORUM FOTOGRAFLARI =====
    match /comments/{commentId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
        && isImage()
        && maxSize(5);
    }

    // Diger her sey yasak
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
