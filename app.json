{
  "expo": {
    "name": "Kaşık - Ek Gıda Rehberi",
    "slug": "kasik-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "kasik",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#A3BA91"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kasik.ekgida",
      "buildNumber": "1",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSCameraUsageDescription": "Tarif ve topluluk paylaşımları için fotoğraf çekmek amacıyla kamera erişimi gereklidir.",
        "NSPhotoLibraryUsageDescription": "Tarif ve topluluk paylaşımlarına fotoğraf eklemek için galeri erişimi gereklidir.",
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "com.kasik.ekgida",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#A3BA91",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#A3BA91",
      "androidMode": "default",
      "androidCollapsedTitle": "Kaşık"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#A3BA91",
          "defaultChannel": "general",
          "sounds": []
        }
      ]
    ]
  }
}
